# Run API on a free port, e.g. 8001 if 8000 is already in use:
#   python -m uvicorn app.main:app --reload --host 127.0.0.1 --port 8001

# NVIDIA NIM API key — get free at https://build.nvidia.com
NIM_API_KEY=

# NIM model for makeup step generation
# Good options: meta/llama-3.3-70b-instruct, meta/llama-3.1-8b-instruct
NIM_MODEL=meta/llama-3.3-70b-instruct

# Replicate — FLUX Fill inpainting (required for final image)
REPLICATE_API_TOKEN=

# Optional FLUX tuning (defaults shown)
FLUX_NUM_INFERENCE_STEPS=28
# 7-9 = conservative inpainting (preserves face). 30+ = creative repaint (destroys identity).
FLUX_GUIDANCE=7.5

# false = no affine warp (recommended; avoids double-eyes / smear when FLUX reshapes face)
FLUX_FACE_ALIGN=false

# Comma-separated origins for CORS (Vite may use 5173, 5174, … if ports are busy)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174
